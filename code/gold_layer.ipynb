   "source": [
    "%sql\n",
    "select fact.ride_id, fact.base_fare, dim.region from uber.bronze.fact as fact\n",
    "LEFT JOIN uber.bronze.dim_location as dim \n",
    "ON \n",
    "    fact.pickup_city_id = dim.pickup_city_id\n",
    "    AND dim.`__END_AT` IS NULL"
   ]
  }
